# Copy to neon.local.env (gitignored) and fill DB_PASSWORD.
# Both services share ONE Neon database: Societywale

SPRING_PROFILES_ACTIVE=prod
DB_URL=jdbc:postgresql://ep-shy-paper-aohwh4tb-pooler.c-2.ap-southeast-1.aws.neon.tech/Societywale?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=REPLACE_WITH_YOUR_NEON_PASSWORD
JWT_SECRET=REPLACE_WITH_SAME_SECRET_FOR_BOTH_SERVICES
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Groq AI assistant (core-service only). Get a key from https://console.groq.com
# Restart core after setting: .\scripts\start-backend-neon.ps1 -Service core
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY
# Optional model override:
# GROQ_MODEL=llama-3.3-70b-versatile

# Gmail SMTP for welcome / owner notification emails (identity-service)
# Google Account → Security → 2-Step Verification → App passwords
MAIL_ENABLED=false
MAIL_USERNAME=societywale.in@gmail.com
MAIL_APP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
MAIL_FROM=societywale.in@gmail.com
MAIL_OWNER_INBOX=societywale.in@gmail.com
MAIL_APP_URL=https://societywale.in
