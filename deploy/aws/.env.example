# Copy to .env on the EC2 server (never commit real secrets)
#   cp .env.example .env

# Same Neon DB you already use
DB_URL=jdbc:postgresql://ep-shy-paper-aohwh4tb-pooler.c-2.ap-southeast-1.aws.neon.tech/Societywale?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=REPLACE_WITH_NEON_PASSWORD

# MUST match on identity + core (same value)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Frontend origins (comma-separated, no trailing slash)
APP_CORS_ORIGINS=https://societywale.vercel.app,https://societywale.in,https://www.societywale.in,http://localhost:5173

# Heap tuning for t3.small (2GB). On t3.medium you can raise MaxRAMPercentage.
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=55.0
