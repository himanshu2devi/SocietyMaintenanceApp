# Copy to .env on the EC2 server (never commit real secrets)
#   cp .env.example .env

# Same Neon DB you already use
DB_URL=jdbc:postgresql://ep-shy-paper-aohwh4tb-pooler.c-2.ap-southeast-1.aws.neon.tech/Societywale?sslmode=require
DB_USER=neondb_owner
DB_PASSWORD=REPLACE_WITH_NEON_PASSWORD

# MUST match on identity + core (same value)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Frontend origins (comma-separated, no trailing slash)
APP_CORS_ORIGINS=https://societywale.vercel.app,https://societywale.in,https://www.societywale.in,http://localhost:5173

# Groq AI assistant for the website chatbot (core-service)
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY

# Gmail SMTP for welcome emails (identity-service) — use a Google App Password
MAIL_ENABLED=false
MAIL_USERNAME=societywale.in@gmail.com
MAIL_APP_PASSWORD=REPLACE_WITH_GMAIL_APP_PASSWORD
MAIL_FROM=societywale.in@gmail.com
MAIL_OWNER_INBOX=societywale.in@gmail.com
MAIL_APP_URL=https://societywale.in

# Razorpay live keys (identity-service) — never commit real secrets
# Dashboard → Settings → API Keys. Use LIVE mode keys for societywale.in.
RAZORPAY_KEY_ID=rzp_live_XXXXXXXX
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_KEY_SECRET
# Optional but recommended: Dashboard → Webhooks → endpoint
#   https://identity.societywale.in/api/v1/payments/razorpay/webhook
# Events: payment.captured, order.paid
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
# Testing: 100 = ₹1. Production early-bird: 499900 = ₹4,999 (put comments on their own line)
RAZORPAY_AMOUNT_PAISE=100
RAZORPAY_LIST_PRICE=9999
RAZORPAY_OFFER_PRICE=4999
RAZORPAY_EARLY_BIRD_LIMIT=10

# Heap tuning for t3.small (2GB). On t3.medium you can raise MaxRAMPercentage.
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=55.0
